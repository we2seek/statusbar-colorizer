{
  "name": "statusbar-colorizer",
  "displayName": "Statusbar Colorizer",
  "description": "Automatically assigns a unique status bar color to each workspace",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "statusbarColorizer.reassign",
        "title": "Statusbar Colorizer: Reassign Color"
      }
    ],
    "configuration": {
      "title": "Statusbar Colorizer",
      "properties": {
        "statusbarColorizer.colorPalette": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Custom color palette (HEX #RRGGBB). Overrides built-in palette.",
          "default": []
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^1.0.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
